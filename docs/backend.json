
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user data including onboarding status and psychological profiling results.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "hasCompletedProfiling": { "type": "boolean" },
        "role": { "type": "string", "enum": ["Founder", "Next Generation", "Advisor"] },
        "generationalStage": { "type": "string" },
        "onboardingData": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "hasCompletedProfiling"]
    },
    "FamilyDNA": {
      "title": "Family DNA",
      "description": "AI-extracted insights regarding family dynamics, friction points, and legacy values.",
      "type": "object",
      "properties": {
        "personalProfile": { "type": "object" },
        "familyProfile": { "type": "object" },
        "initialTimeline": { "type": "array", "items": { "$ref": "#/entities/TimelineEvent" } }
      }
    },
    "TimelineEvent": {
      "title": "Timeline Event",
      "description": "A human-centric milestone in the family legacy timeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["financial", "personal", "succession", "philanthropy", "vision"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "in-progress", "upcoming", "target"] }
      }
    },
    "FamilyScenario": {
      "title": "Family Scenario",
      "description": "A draft 'Life Move' or potential event being planned in the sandbox.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "simulated", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PhysicalAsset": {
      "title": "Physical Asset",
      "description": "Manually added asset such as real estate, art, or private holdings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Real Estate", "Art", "Private Equity", "Collectibles", "Jewelry", "Other"] },
        "appraisalValue": { "type": "number" },
        "appraisalDate": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "documentCount": { "type": "number" }
      },
      "required": ["name", "type", "appraisalValue"]
    },
    "Recommendation": {
      "title": "Family Recommendation",
      "description": "AI-generated actionable advice for the family ecosystem.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "targetMember": { "type": "string" },
        "impact": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A secure message within the family group chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "recommendation"] },
        "recommendationId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user document"
    },
    "/users/{userId}/dna/current": {
      "schema": "FamilyDNA",
      "description": "Extracted family DNA insights"
    },
    "/users/{userId}/timeline/{eventId}": {
      "schema": "TimelineEvent",
      "description": "Generational timeline milestones"
    },
    "/users/{userId}/scenarios/{scenarioId}": {
      "schema": "FamilyScenario",
      "description": "Draft life moves and planning notes"
    },
    "/users/{userId}/assets/{assetId}": {
      "schema": "PhysicalAsset",
      "description": "Manual physical assets and appraisals"
    },
    "/users/{userId}/recommendations/{recId}": {
      "schema": "Recommendation",
      "description": "AI-generated family recommendations"
    },
    "/users/{userId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "Secure chat history"
    }
  }
}
