{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user data including onboarding status and psychological profiling results.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "hasCompletedProfiling": { "type": "boolean" },
        "role": { "type": "string", "enum": ["Founder", "Next Generation", "Advisor"] },
        "generationalStage": { "type": "string" },
        "onboardingData": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "hasCompletedProfiling"]
    },
    "FamilyDNA": {
      "title": "Family DNA",
      "description": "AI-extracted insights regarding family dynamics, friction points, and legacy values. Acts as a Wikipedia-style profile.",
      "type": "object",
      "properties": {
        "personalProfile": {
          "type": "object",
          "properties": {
            "roleInFamily": { "type": "string" },
            "generationalStage": { "type": "string" },
            "primaryLocation": { "type": "string" },
            "otherLocations": { "type": "array", "items": { "type": "string" } },
            "psychologicalProfile": { "type": "object" },
            "financialSnapshot": { "type": "object" },
            "aiSummary": { "type": "string" }
          }
        },
        "familyProfile": {
          "type": "object",
          "properties": {
            "familyName": { "type": "string" },
            "currentGenerationalStage": { "type": "string" },
            "geographicFootprint": { "type": "array", "items": { "type": "string" } },
            "wealthSource": { "type": "string" },
            "estimatedTotalNetWorth": { "type": "string" },
            "history": { "type": "object" },
            "identifiedMembers": { "type": "array", "items": { "$ref": "#/entities/FamilyMember" } },
            "socialCapital": { "type": "object" },
            "relationalDynamics": { "type": "object" },
            "familyLegacyNarrative": { "type": "string" }
          }
        },
        "initialTimeline": { "type": "array", "items": { "$ref": "#/entities/TimelineEvent" } }
      }
    },
    "FamilyMember": {
      "title": "Family Member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "relationship": { "type": "string" },
        "generationalStage": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "TimelineEvent": {
      "title": "Timeline Event",
      "description": "A human-centric milestone in the family legacy timeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["financial", "personal", "succession", "philanthropy", "vision"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "in-progress", "upcoming", "target"] }
      }
    },
    "PhysicalAsset": {
      "title": "Physical Asset",
      "description": "Manually added asset such as real estate, art, or private holdings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Real Estate", "Art", "Private Equity", "Collectibles", "Jewelry", "Other"] },
        "appraisalValue": { "type": "number" },
        "appraisalDate": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "documentCount": { "type": "number" }
      },
      "required": ["name", "type", "appraisalValue"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user document"
    },
    "/users/{userId}/dna/current": {
      "schema": "FamilyDNA",
      "description": "Extracted family DNA insights"
    },
    "/users/{userId}/timeline/{eventId}": {
      "schema": "TimelineEvent",
      "description": "Generational timeline milestones"
    },
    "/users/{userId}/assets/{assetId}": {
      "schema": "PhysicalAsset",
      "description": "Manual physical assets and appraisals"
    }
  }
}